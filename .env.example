# Database
DATABASE_URL="postgresql://clinic:clinic_secret@localhost:5432/clinic_management?schema=public"

# API Server
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_DAYS=30

# OTP (dev: codes logged to console)
OTP_EXPIRY_MINUTES=10

# Notifications (optional — stubs work without keys)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clinic.app

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MediQueue Clinic
